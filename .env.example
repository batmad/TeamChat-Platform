# App
NODE_ENV=development
APP_NAME="Syscca TeamChat Platform"
APP_URL="http://localhost:3000"
PORT=3000
APP_ORIGIN="localhost"
APP_BASE_PATH=""

# Metadata
METADATA_TITLE="Syscca TeamChat Platform"
METADATA_DESCRIPTION="Central realtime floating chat platform"

# PostgreSQL internal database
DATABASE_URL="postgresql://chat_app:chat_app_password@localhost:5432/realtime_chat?schema=public"

# Session
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-secret-minimum-32-characters"
SESSION_TTL_SECONDS=28800

# Chat widget authentication
# Separate session signing key for external widget sessions.
CHAT_SESSION_SECRET="replace-with-a-separate-chat-session-secret-minimum-32-characters"
CHAT_SESSION_TTL_SECONDS=28800
# Maximum lifetime accepted for host-generated bootstrap tokens.
WIDGET_BOOTSTRAP_MAX_TTL_SECONDS=300

# Application signing credential encryption
# Used to encrypt host application signing secrets at rest.
APPLICATION_CREDENTIAL_ENCRYPTION_KEY="replace-with-a-separate-credential-encryption-key-minimum-32-characters"

# Integration secret encryption
# Recommended: use a different random secret from SESSION_SECRET.
# Generate with: openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY="replace-with-a-separate-random-secret-minimum-32-characters"

# ROOT bootstrap (used by `npm run prisma:seed`)
ROOT_USERNAME="root"
ROOT_NAME="System Root"
ROOT_PASSWORD="change-this-strong-password"

# Logging
LOG_LEVEL="debug"

# Realtime Socket.IO service (same repository, dedicated process)
REALTIME_URL="http://localhost:3001"
REALTIME_HOST="0.0.0.0"
REALTIME_PORT=3001
REALTIME_PATH="/socket.io"
REALTIME_PING_INTERVAL_MS=25000
REALTIME_PING_TIMEOUT_MS=20000
REALTIME_HEARTBEAT_INTERVAL_MS=25000
REALTIME_OFFLINE_GRACE_MS=15000
REALTIME_CONNECTION_RECOVERY_MS=120000
REALTIME_MESSAGE_RATE_LIMIT_WINDOW_MS=10000
REALTIME_MESSAGE_RATE_LIMIT_MAX=30
PRESENCE_CLEANUP_INTERVAL_MS=3600000
