{
  "name": "syscca-teamchat-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/start-next.mjs dev",
    "dev:realtime": "tsx --conditions=react-server server/realtime.ts",
    "build": "next build",
    "start": "node scripts/start-next.mjs start",
    "start:realtime": "tsx --conditions=react-server server/realtime.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prisma:reset": "prisma migrate reset",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "prisma:deploy": "prisma migrate deploy",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "logs:retention": "tsx scripts/run-log-retention.ts",
    "test:quality": "npm run lint && npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "argon2": "0.45.0",
    "dotenv": "17.4.2",
    "exceljs": "^4.4.0",
    "jose": "6.2.3",
    "mysql2": "3.15.3",
    "next": "16.2.10",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "sonner": "^2.0.7",
    "tsx": "^4.23.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "pino-pretty": "^13.1.1",
    "prisma": "7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}